@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Qt6 REQUIRED COMPONENTS Core Gui Qml Quick QuickControls2 Svg)

include("${CMAKE_CURRENT_LIST_DIR}/GeoControlsTargets.cmake")

set(GeoControls_ICON_DIR "${PACKAGE_PREFIX_DIR}/@GEOCONTROLS_ICON_INSTALL_DIR@")
set(GeoControls_APP_ICON_ICO "${GeoControls_ICON_DIR}/AppIcon.ico")
set(GeoControls_APP_ICON_ICNS "${GeoControls_ICON_DIR}/AppIcon.icns")
set(GeoControls_APP_ICON_PNG "${GeoControls_ICON_DIR}/AppIcon.png")
set(GeoControls_DOCUMENT_ICON_ICO "${GeoControls_ICON_DIR}/GeoControlsFiles.ico")
set(GeoControls_DOCUMENT_ICON_ICNS "${GeoControls_ICON_DIR}/GeoControlsFiles.icns")
set(GeoControls_DOCUMENT_ICON_PNG "${GeoControls_ICON_DIR}/GeoControlsFiles.png")

check_required_components(GeoControls)
